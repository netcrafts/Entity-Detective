<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusion filter for Entity Detective.

  Categories of false positives suppressed here:
  1. Mixin classes — SpotBugs cannot follow @Inject / @Shadow semantics and flags
     the generated bytecode as broken (uninitialized fields, dead stores, etc.).
  2. Minecraft internals / remapped names — registry/NBT APIs use patterns that look
     like bugs to static analysis but are intentional.
  3. EI_EXPOSE_REP / MS_* — Minecraft uses mutable collections / arrays by convention.
-->
<FindBugsFilter>

    <!-- ── Mixin classes ─────────────────────────────────────────────────── -->
    <!-- All mixins: suppress everything; bytecode after weaving is not ours -->
    <Match>
        <Class name="~netcrafts\.detective\.mixin\..*"/>
        <Bug pattern="UWF_UNWRITTEN_FIELD,UWF_NULL_FIELD,NP_UNWRITTEN_PUBLIC_OR_PROTECTED_FIELD,
                       DLS_DEAD_LOCAL_STORE,URF_UNREAD_FIELD,SF_SWITCH_FALLTHROUGH"/>
    </Match>

    <!-- ── Brigadier command source — always non-null at call sites ─────── -->
    <Match>
        <Class name="~netcrafts\.detective\.commands\..*"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    </Match>

    <!-- ── Minecraft registry getKey() returns null for unregistered types ─ -->
    <!-- We already guard these; suppress duplicate nullability warnings      -->
    <Match>
        <Class name="netcrafts.detective.query.EntityQuery"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    </Match>

    <!-- ── Mutable return type from Minecraft's own APIs ───────────────── -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

</FindBugsFilter>
